# ============================================================
# Ticket Price Tracker - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# --- SeatGeek API ---
# Get your free key at: https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_here
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_here

# --- Ticketmaster Discovery API (optional) ---
# Get your free key at: https://developer.ticketmaster.com/
# Works without it (scraping), but API is more reliable (5000 calls/day free)
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# --- Twilio SMS ---
# Sign up at: https://www.twilio.com (free trial = $15 credit)
# Find credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567
TWILIO_TO_NUMBER=+15559876543
