# ============================================================
# Ticket Price Tracker - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# --- SeatGeek API ---
# Get your free key at: https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=your_seatgeek_client_id_here
SEATGEEK_CLIENT_SECRET=your_seatgeek_client_secret_here

# --- Ticketmaster Discovery API (optional) ---
# Get your free key at: https://developer.ticketmaster.com/
# Works without it (scraping), but API is more reliable (5000 calls/day free)
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# --- SMS Alerts (FREE via Email-to-SMS Gateway) ---
# Uses your email to send texts through carrier gateways - no paid service needed!
#
# For Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail"
#   4. Use that 16-character password below (NOT your regular Gmail password)
#
# For Outlook/Yahoo: similar app password process
SMTP_EMAIL=you@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop

# Your phone number (digits only, no +1, no dashes)
PHONE_NUMBER=5551234567

# Your carrier (see list below)
# US: att, tmobile, verizon, sprint, uscellular, metropcs, boost, cricket,
#     mint, googlefi, visible, xfinity, straight_talk, consumer_cellular
# Canada: rogers, bell, telus, fido, koodo
PHONE_CARRIER=verizon
